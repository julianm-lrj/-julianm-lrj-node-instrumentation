{
  "name": "@julianm-lrj/node-instrumentation",
  "version": "0.6.1",
  "description": "Production-focused OpenTelemetry instrumentation helpers for Node, Express, and h3.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "tsx --test test/*.test.ts",
    "test:esm": "node test/import-esm.test.mjs",
    "test:cjs": "node test/require-cjs.test.cjs",
    "test:formats": "npm run build && npm run test:esm && npm run test:cjs",
    "test:coverage": "c8 --all --include=src/*.ts --exclude=dist/**,coverage/**,node_modules/** --reporter=text-summary --reporter=lcov --check-coverage --lines 90 --branches 80 --functions 95 --statements 90 --skip-full tsx --test test/*.test.ts",
    "licenses:generate": "node licence/generate-third-party-license-report.mjs"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "peerDependencies": {
    "express": ">=4",
    "h3": ">=1"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "h3": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/api": "latest",
    "@opentelemetry/api-logs": "latest",
    "@opentelemetry/context-async-hooks": "latest",
    "@opentelemetry/core": "latest",
    "@opentelemetry/exporter-logs-otlp-http": "latest",
    "@opentelemetry/exporter-metrics-otlp-http": "latest",
    "@opentelemetry/exporter-trace-otlp-http": "latest",
    "@opentelemetry/resources": "latest",
    "@opentelemetry/sdk-logs": "latest",
    "@opentelemetry/sdk-metrics": "latest",
    "@opentelemetry/sdk-trace-base": "latest",
    "@opentelemetry/sdk-trace-node": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/express": "latest",
    "c8": "latest",
    "eslint": "latest",
    "express": "latest",
    "globals": "latest",
    "h3": "latest",
    "tsup": "^8.5.1",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
